# ── Backend (Docker local) ────────────────────────────────────────────────
BACKEND_PORT=8000

# Para demo via ngrok com frontend na Vercel: troque para "production"
# Isso ativa cookies SameSite=None; Secure (necessário cross-site).
ENV=development

JWT_SECRET=changeme_use_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Supabase Postgres ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres.PROJ:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://PROJ.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=frames

# ── CORS / origins permitidos ─────────────────────────────────────────────
# Lista separada por vírgula. Para demo via Vercel + ngrok, inclua a URL
# pública do frontend. URLs *.vercel.app já são aceitas via regex em main.py.
FRONTEND_URL=http://localhost:3000
